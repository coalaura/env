{
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingComments": "always",
    "editor.codeLensFontFamily": "'ComicCode Nerd Font', Consolas, 'Courier New', monospace",
    "editor.emptySelectionClipboard": false,
    "editor.fontFamily": "'ComicCode Nerd Font', 'Comic Code', Consolas, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.indentSize": "tabSize",
    "editor.inlineSuggest.enabled": false,
    "editor.insertSpaces": false,
    "editor.renderWhitespace": "none",
    "editor.rulers": [
        80
    ],
    "editor.unicodeHighlight.nonBasicASCII": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "workbench.colorCustomizations": {
        "editorRuler.foreground": "#363a4f"
    },
    "workbench.colorTheme": "Catppuccin Macchiato",
    "workbench.editor.defaultBinaryEditor": "hexEditor.hexedit",
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.wrapTabs": true,
    "workbench.editorAssociations": {
        "*.svg": "imagePreview.previewEditor",
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.png": "imagePreview.previewEditor",
        "*.dat": "default",
        "*.rpf": "hexEditor.hexedit",
        "*.lib": "hexEditor.hexedit",
        "*.bin": "hexEditor.hexedit",
        "*.lar": "hexEditor.hexedit",
        "*.dll": "hexEditor.hexedit",
        "*.db": "sqlite3-editor.editor"
    },
    "workbench.iconTheme": "catppuccin-macchiato",
    "workbench.quickOpen.preserveInput": true,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 10,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "files.associations": {
        "*.css": "css",
        "*.html": "html",
        "*.meta": "xml",
        "*.vue": "html"
    },
    "files.readonlyInclude": {
        "**/node_modules/**": true,
        "**/vendor/**": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/bower_components/*/**": true,
        "**/dist/**": true,
        "**/build/**": true
    },
    "search.defaultViewMode": "tree",
    "search.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.hg": true,
        "**/.svn": true,
        "**/*.7z": true,
        "**/*.avi": true,
        "**/*.bin": true,
        "**/*.bmp": true,
        "**/*.class": true,
        "**/*.dll": true,
        "**/*.dylib": true,
        "**/*.exe": true,
        "**/*.flac": true,
        "**/*.gif": true,
        "**/*.gz": true,
        "**/*.ico": true,
        "**/*.iso": true,
        "**/*.jar": true,
        "**/*.jpeg": true,
        "**/*.jpg": true,
        "**/*.mkv": true,
        "**/*.mov": true,
        "**/*.mp3": true,
        "**/*.mp4": true,
        "**/*.o": true,
        "**/*.obj": true,
        "**/*.pdf": true,
        "**/*.png": true,
        "**/*.pyc": true,
        "**/*.pyd": true,
        "**/*.pyo": true,
        "**/*.rar": true,
        "**/*.so": true,
        "**/*.tar": true,
        "**/*.tiff": true,
        "**/*.wav": true,
        "**/*.zip": true,
        "**/build": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/bower_components": true,
        "**/Thumbs.db": true,
        "**/vendor": true
    },
    "search.followSymlinks": true,
    "search.quickOpen.history.filterSortOrder": "recency",
    "search.ripgrep.maxThreads": 8,
    "search.searchEditor.reusePriorSearchConfiguration": true,
    "search.searchEditor.singleClickBehaviour": "peekDefinition",
    "search.searchOnTypeDebouncePeriod": 400,
    "search.showLineNumbers": true,
    "search.useGlobalIgnoreFiles": false,
    "search.useIgnoreFiles": false,
    "git.autoStash": true,
    "git.autofetch": true,
    "git.blame.editorDecoration.enabled": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.followTagsWhenSync": true,
    "git.ignoreRebaseWarning": true,
    "git.mergeEditor": true,
    "git.openRepositoryInParentFolders": "never",
    "git.rebaseWhenSync": true,
    "git.replaceTagsWhenPull": true,
    "scm.alwaysShowRepositories": true,
    "scm.defaultViewMode": "tree",
    "scm.inputMinLineCount": 2,
    "scm.repositories.sortOrder": "path",
    "outline.showEnumMembers": false,
    "outline.showTypeParameters": false,
    "security.workspace.trust.untrustedFiles": "open",
    "update.showReleaseNotes": false,
    "telemetry.feedback.enabled": false,
    "chat.agent.enabled": false,
    "chat.editRequests": "none",
    "extensions.autoUpdate": "off",
    "extensions.webWorker": true,
    "task.allowAutomaticTasks": "off",
    "css.format.maxPreserveNewLines": 3,
    "css.format.spaceAroundSelectorSeparator": true,
    "css.hover.references": false,
    "css.lint.compatibleVendorPrefixes": "warning",
    "css.lint.duplicateProperties": "error",
    "html.format.extraLiners": "",
    "html.format.indentHandlebars": true,
    "html.format.indentInnerHtml": true,
    "html.format.maxPreserveNewLines": 2,
    "html.format.templating": true,
    "html.format.wrapAttributes": "auto",
    "html.format.wrapLineLength": 240,
    "html.hover.documentation": false,
    "html.hover.references": false,
    "json.schemaDownload.trustedDomains": {
        "https://biomejs.dev": true,
        "https://developer.microsoft.com/json-schemas/": true,
        "https://json-schema.org/": true,
        "https://json.schemastore.org/": true,
        "https://models.dev/model-schema.json": true,
        "https://opencode.ai/config.json": true,
        "https://raw.githubusercontent.com/": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://schemastore.azurewebsites.net/": true,
        "https://www.schemastore.org/": true
    },
    "[css]": {
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[java]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "always"
        }
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.wordWrap": "on",
        "diffEditor.ignoreTrimWhitespace": true
    },
    "[pcss]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[php]": {
        "editor.defaultFormatter": "kokororin.vscode-phpfmt"
    },
    "[plaintext]": {
        "editor.wordWrap": "on"
    },
    "[scss]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar"
    },
    "auto-rename-tag.activationOnLanguage": [
        "html"
    ],
